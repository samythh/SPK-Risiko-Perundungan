// File: backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL") // Kembali menggunakan cara normal dan stabil
}

// Model Tabel User untuk Login Guru BK
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("GURU_BK")
  createdAt DateTime @default(now())
}

// Model Tabel Kriteria AHP
model Kriteria {
  id      Int     @id @default(autoincrement())
  kode    String  @unique 
  nama    String
  bobot   Float?  
  tipe    String  
}