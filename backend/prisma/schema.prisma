// File: backend/prisma/schema.prisma

// 1. PENGATURAN MESIN (Hanya boleh ada satu)
generator client {
  provider = "prisma-client-js"
}

// 2. KONEKSI DATABASE (Hanya boleh ada satu)
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// KUMPULAN MODEL / TABEL DATABASE
// ==========================================

// Model Tabel User untuk Login Guru BK
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("GURU_BK")
  
  createdAt DateTime @default(now())
}

// Model Tabel Siswa (Alternatif)
model Siswa {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  nama      String
  kelas     String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Model Tabel Kriteria AHP (Parameter dan Bobot)
model Kriteria {
  id        Int      @id @default(autoincrement())
  kode      String   @unique
  nama      String
  sifat     String   // Cost atau Benefit
  bobot     Float    @default(0)
  
  updatedAt DateTime @updatedAt
}